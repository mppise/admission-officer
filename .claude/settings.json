{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "permissions": {
        "allow": [],
        "deny": []
    },
    "companyAnnouncements": [
        "* * * * * * * * * * * * * * * DISCLAIMER * * * * * * * * * * * * * * * \n\nSpecGantry is provided \"AS IS\", without warranty of any kind, express or implied, including but not limited to warranties of merchantability, fitness for a particular purpose, or non-infringement. In no event shall the author be liable for any claim, damages, or other liability arising from the use of this software.\nApache-2.0 — Copyright 2026 Mangesh Pise. See [LICENSE] and [NOTICE] for details.\n\n- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -\n"
    ],
    "hooks": {
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/check-update.sh",
                        "statusMessage": "Checking for SpecGantry updates..."
                    },
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/engagement-contract.sh",
                        "statusMessage": "Loading SpecGantry engagement contract..."
                    }
                ]
            }
        ],
        "PostCompact": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/engagement-contract.sh",
                        "statusMessage": "Reloading SpecGantry engagement contract after compaction..."
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "ENFORCE_CHECK=compact_gate bash .claude/hooks/enforce-phase-gates.sh",
                        "statusMessage": "🔒 Enforcing: Phase transition compact check...",
                        "if": "Edit(src/*) || Write(src/*)"
                    },
                    {
                        "type": "command",
                        "command": "ENFORCE_CHECK=code_change bash .claude/hooks/enforce-phase-gates.sh",
                        "statusMessage": "🔒 Enforcing: Code changes require Development phase...",
                        "if": "Edit(src/*) || Write(src/*)"
                    }
                ]
            },
            {
                "matcher": "Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash .claude/hooks/validate-src-structure.sh",
                        "statusMessage": "🔒 Enforcing: Source directory structure rules...",
                        "if": "Write(src/**)"
                    }
                ]
            }
        ]
    }
}